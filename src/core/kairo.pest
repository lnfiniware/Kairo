WHITESPACE = _{ " " | "\t" | "\r" | "\n" }
COMMENT = _{ "//" ~ (!"\n" ~ ANY)* }

schema = { SOI ~ table* ~ EOI }

table = { "table" ~ ident ~ "{" ~ field* ~ "}" }

field = { ident ~ ":" ~ type_name ~ ("=" ~ default_value)? }

ident = @{ (ASCII_ALPHA | "_") ~ (ASCII_ALPHANUMERIC | "_")* }

type_name = @{ ASCII_ALPHA+ }

default_value = { bool_lit | int_lit | string_lit }

bool_lit = { "true" | "false" }
int_lit = @{ "-"? ~ ASCII_DIGIT+ }
string_lit = @{ "\"" ~ (!"\"" ~ ANY)* ~ "\"" }
